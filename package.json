{
  "name": "codexpane",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "docs:build-manifest": "node ./scripts/docs-manifest.mjs && node ./scripts/docs-sync-images.mjs",
    "docs:check-nbsp-content": "node ./scripts/docs-check-nbsp-content.mjs",
    "docs:normalize-raw": "node ./scripts/docs-normalize-raw-nbsp.mjs",
    "docs:validate": "npm run docs:check-nbsp-content && node ./scripts/docs-manifest.mjs --validate",
    "data:refresh": "node ./scripts/static-data/refresh-static-data.mjs",
    "dev": "npm run docs:build-manifest && vite",
    "build": "npm run docs:build-manifest && vite build",
    "lint": "npm run docs:validate && eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mdx-js/react": "^3.1.1",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "@reduxjs/toolkit": "^2.9.0",
    "@tailwindcss/vite": "^4.1.14",
    "github-markdown-css": "^5.8.1",
    "minisearch": "^7.2.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@mdx-js/rollup": "^3.1.1",
    "@types/react": "^19.1.16",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "github-slugger": "^2.0.0",
    "globals": "^16.4.0",
    "remark-frontmatter": "^5.0.0",
    "vite": "npm:rolldown-vite@7.1.14"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.1.14"
  }
}
